# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/resolvenow

# Session Secret (ใส่ข้อความสุ่มยาวๆ เพื่อความปลอดภัย)
SESSION_SECRET=your_random_secret_key_here

# Email (SendGrid HTTP API — ไม่ใช้ SMTP)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
MAIL_USER=your_verified_sender@gmail.com

# LINE Notify / Messaging API
LINE_CHANNEL_TOKEN=your_line_channel_access_token_here
LINE_ADMIN_USER_ID=your_line_user_id_here

# LINE Login OAuth
LINE_LOGIN_CLIENT_ID=your_line_login_client_id_here
LINE_LOGIN_CLIENT_SECRET=your_line_login_client_secret_here
LINE_LOGIN_CALLBACK_URL=https://your-domain.onrender.com/auth/line/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Anthropic Claude AI (วิเคราะห์ระดับความเร่งด่วน)
# ขอ API Key ฟรีได้ที่: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
BASE_URL=https://your-domain.onrender.com
